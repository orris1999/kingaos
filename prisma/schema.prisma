generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String
  department      String
  role            String
  isActive        Boolean   @default(true)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?

  permissions UserPermission[]
  sessions    UserSession[]

  @@index([department])
  @@index([role])
  @@index([isActive])
}

model Permission {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  group     String
  reserved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPermissions UserPermission[]
}

model UserPermission {
  id            String @id @default(cuid())
  userId        String
  permissionKey String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([permissionKey])
}

model UserSession {
  id               String    @id @default(cuid())
  sessionTokenHash String    @unique
  userId           String
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Customer {
  id                                    String                 @id @default(cuid())
  customerCode                          String                 @unique
  name                                  String
  customerIdentityId                    String?
  customerIdentity                      CustomerIdentity?      @relation(fields: [customerIdentityId], references: [id], onDelete: SetNull)
  normalizedCustomerName                String?
  duplicateApprovalStatus               String                 @default("none")
  duplicateApprovalRequestId            String?
  duplicateApprovedByUserId             String?
  duplicateApprovedByName               String?
  duplicateApprovedAt                   DateTime?
  duplicateApprovalReason               String?
  defaultReceiptAccountId               String?
  defaultReceiptAccount                 CompanyReceiptAccount? @relation(fields: [defaultReceiptAccountId], references: [id], onDelete: SetNull)
  defaultReceiptAccountSelectedAt       DateTime?
  defaultReceiptAccountSelectedByUserId String?
  defaultReceiptAccountSelectedByName   String?
  defaultReceiptAccountNote             String?
  customerType                          String
  customerTypes                         Json                   @default("[]")
  country                               String                 @default("")
  countryCode                           String?
  countryName                           String?
  stateCode                             String?
  stateName                             String?
  cityName                              String?
  city                                  String                 @default("")
  source                                String                 @default("")
  status                                String
  ownerUserId                           String
  ownerName                             String
  department                            String                 @default("export")
  contactName                           String                 @default("")
  contactTitle                          String                 @default("")
  phone                                 String                 @default("")
  email                                 String                 @default("")
  wechatOrWhatsapp                      String                 @default("")
  companyName                           String                 @default("")
  companyWebsite                        String                 @default("")
  companyAddress                        String                 @default("")
  mainProducts                          String                 @default("")
  purchaseNeed                          String                 @default("")
  sourceNote                            String                 @default("")
  expectedPurchaseNeed                  String                 @default("")
  customerNotes                         String                 @default("")
  internalNotes                         String                 @default("")
  specialReminder                       String                 @default("")
  customFields                          Json                   @default("{}")
  createdByUserId                       String
  createdAt                             DateTime               @default(now())
  updatedAt                             DateTime               @updatedAt
  archivedAt                            DateTime?

  contacts             CustomerContact[]
  attachments          CustomerAttachment[]
  fieldChangeHistories CustomerFieldChangeHistory[]

  @@index([customerIdentityId])
  @@index([defaultReceiptAccountId])
  @@index([normalizedCustomerName])
  @@index([duplicateApprovalStatus])
  @@index([ownerUserId])
  @@index([department])
  @@index([status])
  @@index([updatedAt])
}

model CompanyReceiptAccount {
  id                 String    @id @default(cuid())
  accountCode        String    @unique
  displayName        String
  scenarioName       String?
  paymentMethod      String?
  currency           String
  companyName        String
  accountNo          String
  bankName           String
  swiftCode          String?
  bankAddress        String?
  usageNotes         String?
  riskNotes          String?
  isActive           Boolean   @default(true)
  effectiveFrom      DateTime?
  effectiveTo        DateTime?
  disabledAt         DateTime?
  disabledReason     String?
  maintainedByUserId String?
  maintainedByName   String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  customers Customer[]

  @@index([currency])
  @@index([paymentMethod])
  @@index([isActive])
  @@index([displayName])
}

model CustomerIdentity {
  id             String   @id @default(cuid())
  scope          String   @default("export_customer")
  displayName    String
  normalizedName String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customers Customer[]

  @@unique([scope, normalizedName])
  @@index([normalizedName])
}

model CustomerDuplicateReviewRequest {
  id                   String    @id @default(cuid())
  department           String    @default("export")
  moduleKey            String    @default("export_customer")
  requestedByUserId    String
  requestedByName      String?
  proposedCustomerName String
  normalizedName       String
  existingIdentityId   String?
  existingCustomerIds  Json?
  requestedPayload     Json?
  requestReason        String?
  status               String    @default("pending")
  decidedByUserId      String?
  decidedByName        String?
  decisionNote         String?
  decidedAt            DateTime?
  createdCustomerId    String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([department])
  @@index([normalizedName])
  @@index([status])
  @@index([requestedByUserId])
}

model CustomerContact {
  id               String   @id @default(cuid())
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name             String
  title            String?
  phone            String?
  email            String?
  wechatOrWhatsapp String?
  isPrimary        Boolean  @default(false)
  notes            String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([customerId])
  @@index([customerId, isPrimary])
  @@index([customerId, sortOrder])
}

model CustomerAttachment {
  id               String    @id @default(cuid())
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  attachmentName   String
  attachmentType   String?
  fieldKey         String?
  fieldLabel       String?
  fileUrl          String?
  storageProvider  String    @default("external_url")
  storageKey       String?
  mimeType         String?
  fileSize         Int?
  description      String?
  uploadedByUserId String?
  uploadedByName   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([customerId])
  @@index([customerId, fieldKey])
  @@index([attachmentType])
  @@index([deletedAt])
}

model CustomerFieldConfig {
  id            String   @id @default(cuid())
  moduleKey     String
  fieldKey      String
  fieldLabel    String
  fieldType     String
  fieldGroup    String
  required      Boolean  @default(false)
  options       Json     @default("[]")
  sortOrder     Int
  isActive      Boolean  @default(true)
  isSystemField Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([moduleKey, fieldKey])
  @@index([moduleKey])
  @@index([fieldGroup])
  @@index([sortOrder])
}

model CustomerFieldChangeHistory {
  id              String   @id @default(cuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fieldKey        String
  fieldLabel      String
  fieldGroup      String?
  fieldKind       String   @default("system")
  fieldType       String?
  oldValue        Json?
  newValue        Json?
  oldDisplayValue String?
  newDisplayValue String?
  changeType      String   @default("update")
  source          String   @default("customer_edit")
  changedByUserId String?
  changedByName   String?
  changedAt       DateTime @default(now())
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([customerId])
  @@index([fieldKey])
  @@index([changedAt])
  @@index([changedByUserId])
}

model QuoteSourceStagingBatch {
  id                   String    @id @default(cuid())
  sourceFileName       String
  adapterId            String
  category             String?
  submittedByRole      String    @default("finance")
  consumerDepartment   String    @default("export")
  dryRunDecisionStatus String
  status               String    @default("draft")
  createdByUserId      String?
  createdByName        String?
  createdAt            DateTime  @default(now())
  confirmedByUserId    String?
  confirmedByName      String?
  confirmedAt          DateTime?
  warnings             Json?
  notes                String?

  rows QuoteSourceStagingRow[]

  @@index([adapterId])
  @@index([category])
  @@index([status])
  @@index([dryRunDecisionStatus])
  @@index([createdAt])
}

model QuoteSourceStagingRow {
  id                     String                  @id @default(cuid())
  batchId                String
  batch                  QuoteSourceStagingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  sourceRowNumber        Int?
  rawKjCode              String?
  standardKjCode         String?
  baseKjCode             String?
  oldKjNo                String?
  fumacrmCode            String?
  dingjieCodeWithoutCap  String?
  dingjieCodeWithCap     String?
  productNameCandidate   String?
  category               String?
  modelCandidate         String?
  specificationCandidate String?
  tradeMode              String                  @default("unknown")
  priceCandidateStatus   String
  hasCostCandidate       Boolean                 @default(false)
  hasQuoteCandidate      Boolean                 @default(false)
  hasPackagingInfo       Boolean                 @default(false)
  hasOemInfo             Boolean                 @default(false)
  visibility             String
  rowStatus              String
  warnings               Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([batchId])
  @@index([standardKjCode])
  @@index([baseKjCode])
  @@index([oldKjNo])
  @@index([fumacrmCode])
  @@index([dingjieCodeWithoutCap])
  @@index([dingjieCodeWithCap])
  @@index([category])
  @@index([rowStatus])
  @@index([visibility])
}

model QuoteSourceUpload {
  id                      String    @id @default(cuid())
  sourceFileName          String
  originalFileName        String
  fileExt                 String?
  mimeType                String?
  fileSize                Int?
  storageProvider         String    @default("aliyun_oss")
  storageKey              String
  uploadStatus            String    @default("uploaded")
  adapterId               String?
  category                String?
  submittedByRole         String    @default("finance")
  consumerDepartment      String    @default("export")
  uploadedByUserId        String?
  uploadedByName          String?
  uploadedAt              DateTime  @default(now())
  notes                   String?
  warnings                Json?
  dryRunStatus            String    @default("not_run")
  dryRunAdapterId         String?
  dryRunCategory          String?
  dryRunSummary           Json?
  dryRunWarnings          Json?
  dryRunAt                DateTime?
  dryRunByUserId          String?
  dryRunByName            String?
  stagingBatchId          String?
  dryRunConfirmedAt       DateTime?
  dryRunConfirmedByUserId String?
  dryRunConfirmedByName   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([adapterId])
  @@index([category])
  @@index([uploadStatus])
  @@index([dryRunStatus])
  @@index([dryRunAt])
  @@index([stagingBatchId])
  @@index([dryRunConfirmedAt])
  @@index([uploadedAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType])
  @@index([createdAt])
}

model QuoteCandidateAmount {
  id                     String   @id @default(cuid())
  stagingBatchId         String
  stagingRowId           String
  sourceUploadId         String?
  sourceColumnName       String?
  sourceColumnDate       String?
  tradeMode              String
  currency               String
  candidateValue         Decimal  @db.Decimal(18, 4)
  source                 String   @default("finance_quote_source_staging")
  status                 String   @default("not_finance_approved")
  visibility             String   @default("finance_only")
  isFinanceApprovedPrice Boolean  @default(false)
  canBeSentToCustomer    Boolean  @default(false)
  requiresFinancePricing Boolean  @default(true)
  importedByUserId       String?
  importedByName         String?
  importedAt             DateTime @default(now())
  warnings               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([stagingBatchId])
  @@index([stagingRowId])
  @@index([sourceUploadId])
  @@index([tradeMode])
  @@index([currency])
  @@index([status])
  @@index([visibility])
}
