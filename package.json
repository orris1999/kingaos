{
  "name": "kingaos",
  "version": "0.1.0",
  "private": true,
  "description": "KingaOS internal business operation system production-lite baseline",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "db:bootstrap-default-users": "node prisma/bootstrap-default-users.mjs",
    "db:local:up": "docker compose -f docker-compose.local.yml up -d",
    "db:local:down": "docker compose -f docker-compose.local.yml down",
    "db:local:logs": "docker compose -f docker-compose.local.yml logs -f",
    "db:dev:migrate": "DATABASE_URL=\"postgresql://kingaos_app:kingaos_dev_password@localhost:5433/kingaos_dev?schema=public\" DIRECT_URL=\"postgresql://kingaos_app:kingaos_dev_password@localhost:5433/kingaos_dev?schema=public\" prisma migrate dev",
    "db:dev:seed": "DATABASE_URL=\"postgresql://kingaos_app:kingaos_dev_password@localhost:5433/kingaos_dev?schema=public\" DIRECT_URL=\"postgresql://kingaos_app:kingaos_dev_password@localhost:5433/kingaos_dev?schema=public\" node prisma/seed.mjs",
    "db:dev:bootstrap": "DATABASE_URL=\"postgresql://kingaos_app:kingaos_dev_password@localhost:5433/kingaos_dev?schema=public\" DIRECT_URL=\"postgresql://kingaos_app:kingaos_dev_password@localhost:5433/kingaos_dev?schema=public\" ALLOW_DEFAULT_USER_BOOTSTRAP=true node prisma/bootstrap-default-users.mjs",
    "db:test:migrate": "DATABASE_URL=\"postgresql://kingaos_app:kingaos_test_password@localhost:5434/kingaos_test?schema=public\" DIRECT_URL=\"postgresql://kingaos_app:kingaos_test_password@localhost:5434/kingaos_test?schema=public\" prisma migrate deploy",
    "db:test:seed": "DATABASE_URL=\"postgresql://kingaos_app:kingaos_test_password@localhost:5434/kingaos_test?schema=public\" DIRECT_URL=\"postgresql://kingaos_app:kingaos_test_password@localhost:5434/kingaos_test?schema=public\" node prisma/seed.mjs",
    "db:test:bootstrap": "DATABASE_URL=\"postgresql://kingaos_app:kingaos_test_password@localhost:5434/kingaos_test?schema=public\" DIRECT_URL=\"postgresql://kingaos_app:kingaos_test_password@localhost:5434/kingaos_test?schema=public\" ALLOW_DEFAULT_USER_BOOTSTRAP=true node prisma/bootstrap-default-users.mjs",
    "backfill:customer-identities": "node scripts/backfill-customer-identities.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@countrystatecity/countries": "^1.0.5",
    "@prisma/client": "6.19.3",
    "ali-oss": "^6.23.0",
    "graceful-fs": "^4.2.11",
    "next": "15.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "prisma": "6.19.3",
    "rollup": "npm:@rollup/wasm-node@^4.60.3",
    "typescript": "5.5.3",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
